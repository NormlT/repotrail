# Required: GitHub PAT (classic) with `repo` scope -- traffic endpoints need push access
GITHUB_TOKEN=ghp_your_token_here
# Required: GitHub user or org whose repos to track
GITHUB_OWNER=your_github_org

# Optional: bearer token to protect the dashboard (leave empty for no auth)
API_KEY=

# Optional: hours between automatic fetches (default: 6)
FETCH_INTERVAL_HOURS=6
# Optional: SQLite database path (default: ./data/repotrail.db)
DB_PATH=./data/repotrail.db
# Optional: server port (default: 8055)
PORT=8055
